# API Configuration
# The base URL of your backend API
# Example: http://localhost:8000 or https://api.example.com
VITE_API_URL=http://localhost:8000

# Optional: Auth token (if using static token for development)
# This will be overridden by localStorage authToken at runtime
# VITE_PUBLIC_API_TOKEN=your_jwt_token_here

# Environment
# Vite automatically sets this to 'development' or 'production'
# NODE_ENV is not needed for Vite, but can be set if needed
